generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth Models ───────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isAdmin       Boolean   @default(false)
  province      String?
  matricYear    Int?
  apsScore      Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  savedBursaries    SavedBursary[]
  savedLearnerships SavedLearnership[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Core Models ───────────────────────────────────────────────────────────────

model Institution {
  id                   String          @id @default(cuid())
  name                 String
  slug                 String          @unique
  type                 InstitutionType
  provinces            String[]
  city                 String?
  website              String?
  phone                String?
  email                String?
  description          String?         @db.Text
  logoUrl              String?
  rank                 String?
  nsfasAccredited      Boolean         @default(false)
  applicationOpenDate  DateTime?
  applicationCloseDate DateTime?
  appCloseDisplay      String?
  featured             Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  qualifications Qualification[]
}

model Qualification {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  institutionId  String
  nqfLevel       Int
  durationMonths Int
  type           QualificationType
  minApsScore    Int?
  annualCostMin  Int?
  annualCostMax  Int?
  fieldOfStudy   String
  description    String?           @db.Text
  subjectReqs    Json?
  nsfasCovered   Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id])
}

model Learnership {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  provider       String
  seta           String?
  nqfLevel       Int
  stipendMin     Int?
  stipendMax     Int?
  durationMonths Int
  deadline       DateTime?
  applicationUrl String?
  provinces      String[]
  isNational     Boolean       @default(false)
  fieldOfStudy   String?
  sector         String?
  description    String?       @db.Text
  requirements   String?       @db.Text
  icon           String?
  status         ListingStatus @default(OPEN)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  saved SavedLearnership[]
}

model Bursary {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  fullName          String?
  provider          String
  category          String?
  icon              String?
  featured          Boolean   @default(false)
  fieldsOfStudy     String[]
  amountDescription String?
  deadline          DateTime?
  applicationUrl    String?
  eligibilityNotes  String?   @db.Text
  isNsfas           Boolean   @default(false)
  isActive          Boolean   @default(true)
  description       String?   @db.Text
  logoUrl           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  saved SavedBursary[]
}

model CareerPath {
  id           String      @id @default(cuid())
  title        String
  slug         String      @unique
  sector       String
  fieldOfStudy String
  icon         String?
  demandLevel  DemandLevel
  salaryEntry  Int?
  salaryMid    Int?
  salarySenior Int?
  description  String?     @db.Text
  outlook      String?
  skills       String[]
  pathways     String[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model SavedBursary {
  userId    String
  bursaryId String
  savedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bursary Bursary @relation(fields: [bursaryId], references: [id], onDelete: Cascade)

  @@id([userId, bursaryId])
}

model SavedLearnership {
  userId        String
  learnershipId String
  savedAt       DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  learnership Learnership @relation(fields: [learnershipId], references: [id], onDelete: Cascade)

  @@id([userId, learnershipId])
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum InstitutionType {
  UNIVERSITY
  TVET
  PRIVATE_COLLEGE
  DISTANCE_LEARNING
  TRAINING_PROVIDER
}

enum QualificationType {
  DEGREE
  DIPLOMA
  CERTIFICATE
  NCV
  NATED
  SHORT_COURSE
  OCCUPATIONAL_CERT
}

enum ListingStatus {
  OPEN
  CLOSED
  UPCOMING
}

enum DemandLevel {
  CRITICAL
  HIGH
  MODERATE
  LOW
}
